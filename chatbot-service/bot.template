{% endblock %}

{% block %}
    {% client %}(.*)(lái thử|chạy thử|đăng ký lái)(.*){% endclient %}
    {% response %}You can book a test ride directly on our website! Please go to the "Book Test Ride" section on the home page or in the motorcycle details to choose a convenient time.{% endresponse %}
{% endblock %}

{% block %}
    {% client %}(.*)(bảo dưỡng|bảo hành|sửa|dịch vụ)(.*){% endclient %}
    {% response %}Our service workshop is always ready to assist you. Please visit the "Services" section on our menu to book a maintenance appointment!{% endresponse %}
{% endblock %}

{% block %}
    {% client %}(.*)(khuyến mãi|giảm giá|voucher|mã giảm|ưu đãi)(.*){% endclient %}
    {% response %}We frequently run great promotions! You can check the "Motorcycles" page to find models on sale, or apply a Promo Code directly on the Checkout page.{% endresponse %}
{% endblock %}

{% block %}
    {% client %}(.*)(nhân viên|hỗ trợ|gặp cskh|người thật)(.*){% endclient %}
    {% response %}If you'd like to connect directly with our customer support staff, please click the "Connect to CSKH Staff" button in the chat or call our Hotline at 1900 1234!{% endresponse %}
{% endblock %}

{% block %}
    {% client %}(.*)(cảm ơn|thank|tốt|ok|oke)(.*){% endclient %}
